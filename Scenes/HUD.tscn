[gd_scene load_steps=2 format=3]
[ext_resource type="Script" path="res://Scripts/HUD.gd" id="1"]

[node name="HUD" type="Control"]
anchors_preset = 6
anchor_right = 1.0
anchor_bottom = 0.0
offset_left = 0.0
offset_top = 0.0
offset_right = 0.0
offset_bottom = 96.0
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.03, 0.02, 0.94)
mouse_filter = 2

[node name="BottomBorder" type="ColorRect" parent="."]
anchors_preset = 0
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 1.0
offset_left = 0.0
offset_top = -2.0
offset_right = 0.0
offset_bottom = 0.0
color = Color(0.788, 0.659, 0.298, 0.25)
mouse_filter = 2

[node name="MainHBox" type="HBoxContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 12.0
offset_top = 8.0
offset_right = -12.0
offset_bottom = -4.0

;; ── LEFT: Player Panel ──
[node name="PlayerPanel" type="HBoxContainer" parent="MainHBox"]
custom_minimum_size = Vector2(380, 0)
size_flags_horizontal = 0

[node name="PortraitFrame" type="ColorRect" parent="MainHBox/PlayerPanel"]
custom_minimum_size = Vector2(52, 52)
size_flags_horizontal = 0
color = Color(0.12, 0.07, 0.04, 1)
mouse_filter = 2

[node name="PlayerInfo" type="VBoxContainer" parent="MainHBox/PlayerPanel"]
offset_left = 4.0
size_flags_horizontal = 3
size_flags_vertical = 8

[node name="ClassLevelLabel" type="Label" parent="MainHBox/PlayerPanel/PlayerInfo"]
text = "Warrior  Lv.1"
add_theme_color_override = { "font_color": Color(0.788, 0.659, 0.298, 1) }
add_theme_font_size_override = { "font_size": 15 }

[node name="HPBar" type="ColorRect" parent="MainHBox/PlayerPanel/PlayerInfo"]
custom_minimum_size = Vector2(140, 8)
size_flags_horizontal = 0
color = Color(0.08, 0.04, 0.02, 1)
mouse_filter = 2

[node name="HPBarFill" type="ColorRect" parent="MainHBox/PlayerPanel/PlayerInfo/HPBar"]
anchor_left = 0.0
anchor_top = 0.0
anchor_bottom = 1.0
anchor_right = 0.0
offset_right = 0.0
color = Color(0.18, 0.55, 0.18, 1)
mouse_filter = 2

[node name="ArmorBar" type="ColorRect" parent="MainHBox/PlayerPanel/PlayerInfo"]
custom_minimum_size = Vector2(140, 6)
size_flags_horizontal = 0
color = Color(0.04, 0.04, 0.08, 1)
mouse_filter = 2

[node name="ArmorBarFill" type="ColorRect" parent="MainHBox/PlayerPanel/PlayerInfo/ArmorBar"]
anchor_left = 0.0
anchor_top = 0.0
anchor_bottom = 1.0
anchor_right = 0.0
offset_right = 0.0
color = Color(0.2, 0.4, 0.7, 1)
mouse_filter = 2

[node name="HPLabel" type="Label" parent="MainHBox/PlayerPanel/PlayerInfo"]
text = "20 / 25"
add_theme_color_override = { "font_color": Color(0.8, 0.7, 0.6, 1) }
add_theme_font_size_override = { "font_size": 11 }

;; ── CENTER: Resources ──
[node name="ResourcesPanel" type="HBoxContainer" parent="MainHBox"]
size_flags_horizontal = 1
size_flags_vertical = 4

[node name="GoldIcon" type="Label" parent="MainHBox/ResourcesPanel"]
text = "✦"
add_theme_color_override = { "font_color": Color(0.788, 0.659, 0.298, 1) }
add_theme_font_size_override = { "font_size": 18 }
custom_minimum_size = Vector2(24, 0)

[node name="GoldLabel" type="Label" parent="MainHBox/ResourcesPanel"]
text = "0"
add_theme_color_override = { "font_color": Color(0.788, 0.659, 0.298, 1) }
add_theme_font_size_override = { "font_size": 16 }
custom_minimum_size = Vector2(50, 0)
;; ── RIGHT: Dungeon Nav ──
[node name="NavPanel" type="HBoxContainer" parent="MainHBox"]
size_flags_horizontal = 0
size_flags_vertical = 4
custom_minimum_size = Vector2(120, 0)

[node name="FloorLabel" type="Label" parent="MainHBox/NavPanel"]
text = "F3 - R7"
add_theme_color_override = { "font_color": Color(0.788, 0.659, 0.298, 1) }
add_theme_font_size_override = { "font_size": 14 }
custom_minimum_size = Vector2(100, 0)

;; ── Weapon/Shield/Status row (bottom of HUD) ──
[node name="BottomRow" type="HBoxContainer" parent="MainHBox"]
mouse_filter = 2
size_flags_horizontal = 0
size_flags_vertical = 0
custom_minimum_size = Vector2(0, 0)

[node name="WeaponRow" type="HBoxContainer" parent="MainHBox/BottomRow"]
mouse_filter = 2

[node name="WeaponLabel" type="Label" parent="MainHBox/BottomRow/WeaponRow"]
text = "⚔ "
add_theme_color_override = { "font_color": Color(0.788, 0.659, 0.298, 1) }
add_theme_font_size_override = { "font_size": 12 }

[node name="WeaponValue" type="Label" parent="MainHBox/BottomRow/WeaponRow"]
text = "None"
add_theme_color_override = { "font_color": Color(0.8, 0.7, 0.6, 1) }
add_theme_font_size_override = { "font_size": 12 }

[node name="ShieldRow" type="HBoxContainer" parent="MainHBox/BottomRow"]
mouse_filter = 2

[node name="ShieldLabel" type="Label" parent="MainHBox/BottomRow/ShieldRow"]
text = "🛡 "
add_theme_color_override = { "font_color": Color(0.788, 0.659, 0.298, 1) }
add_theme_font_size_override = { "font_size": 12 }

[node name="ShieldValue" type="Label" parent="MainHBox/BottomRow/ShieldRow"]
text = "None"
add_theme_color_override = { "font_color": Color(0.8, 0.7, 0.6, 1) }
add_theme_font_size_override = { "font_size": 12 }
